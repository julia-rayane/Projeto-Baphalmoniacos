generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Categoria {
  id       Int       @id @default(autoincrement())
  nome     String
  produtos Produto[]
}

model Produto {
  id              Int       @id @default(autoincrement())
  nome            String
  descricao       String
  preco           Float
  foto            String
  id_categoria_fk Int
  categoria       Categoria @relation(fields: [id_categoria_fk], references: [id])
}
